# NeuralVaultCore v1.0 - Configuration
# Copy to .env and fill in values. NEVER commit .env.

# Profile: local-stdio | local-ui | remote-homelab
NVC_PROFILE=local-stdio

# Transport: stdio | sse
# Legacy value "http" is normalized to "sse".
NVC_TRANSPORT=stdio

# API key for remote-homelab. Must start with nvc_ and be exactly 52 chars.
# Generate with: python -c "import secrets; print('nvc_' + secrets.token_hex(24))"
NVC_API_KEY=nvc_000000000000000000000000000000000000000000000000

# Storage
NVC_DB_PATH=./data/nvc.db

# MCP server
NVC_HOST=127.0.0.1
NVC_MCP_HOST=127.0.0.1
NVC_PORT=9998
NVC_MCP_PORT=9998

# Auth override
NVC_AUTH=false

# Web UI
NVC_UI_HOST=127.0.0.1
NVC_UI_PORT=9999

# Limits
NVC_SNIPPET_LENGTH=250
NVC_MAX_CONTENT_LENGTH=1000000
NVC_SEARCH_LIMIT=50
NVC_MAX_VERSIONS_KEPT=5
NVC_MAX_KEY_LENGTH=256
NVC_MAX_TITLE_LENGTH=512
NVC_MAX_TAGS_LENGTH=1024

# Observability
NVC_LOG_TOKENS=false
NVC_LOG_JSON=false
